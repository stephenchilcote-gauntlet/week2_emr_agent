FROM openemr/openemr:flex

# Copy pre-built OpenEMR source (includes vendor/, node_modules/, built assets)
COPY --chown=apache:apache ./openemr/ /var/www/localhost/htdocs/openemr/

# Copy canonical sidebar assets from web/sidebar/ into the OpenEMR module.
# web/sidebar/ is the single source of truth; the module directory only keeps
# OpenEMR-specific files (embed.js, proxy.php, sidebar_frame.php).
COPY --chown=apache:apache ./web/sidebar/sidebar.js /var/www/localhost/htdocs/openemr/interface/modules/custom_modules/oe-module-clinical-assistant/public/assets/sidebar.js
COPY --chown=apache:apache ./web/sidebar/sidebar.css /var/www/localhost/htdocs/openemr/interface/modules/custom_modules/oe-module-clinical-assistant/public/assets/sidebar.css
COPY --chown=apache:apache ./web/sidebar/overlay.js /var/www/localhost/htdocs/openemr/interface/modules/custom_modules/oe-module-clinical-assistant/public/assets/overlay.js

# Skip the git clone at startup. Create empty /openemr so the
# EASY_DEV_MODE_NEW rsync is a harmless no-op (--ignore-existing).
ENV EASY_DEV_MODE_NEW=yes
RUN mkdir -p /openemr /couchdb/data

# Wrapper script that installs Let's Encrypt certs before openemr.sh runs ssl.sh
COPY docker/start.sh /var/www/localhost/htdocs/start.sh
RUN chmod +x /var/www/localhost/htdocs/start.sh
CMD ["./start.sh"]
