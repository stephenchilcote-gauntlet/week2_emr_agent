# Production environment — copy to .env.prod and fill in values
# Usage: cp .env.prod.example .env.prod

# Database (use strong random passwords)
MYSQL_ROOT_PASSWORD=CHANGE_ME_random_32_chars
MYSQL_PASSWORD=CHANGE_ME_random_32_chars

# OpenEMR admin UI password
OPENEMR_ADMIN_PASS=CHANGE_ME_strong_password

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenEMR OAuth2 credentials (set after first boot — see README)
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
