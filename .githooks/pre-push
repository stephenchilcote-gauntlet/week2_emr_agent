#!/usr/bin/env bash
# pre-push safety hook — blocks the most common multi-agent coordination failures.
#
# Checks:
#   1. Not pushing from a detached HEAD (no branch = no recovery path)
#   2. Not pushing while behind origin (would clobber parallel work)
#   3. Warn (not block) on direct push to master/main without a PR
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# To bypass in a genuine emergency:
#   git push --no-verify

set -euo pipefail

REMOTE="$1"   # e.g. "origin"
# $2 is the remote URL, not used

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

fail() { echo -e "${RED}pre-push BLOCKED: $*${NC}" >&2; exit 1; }
warn() { echo -e "${YELLOW}pre-push WARNING: $*${NC}" >&2; }

# ── 1. Detached HEAD ────────────────────────────────────────────────────────
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [ -z "$BRANCH" ]; then
    fail "you are on a detached HEAD — create a branch first:
  git switch -c <your-branch-name>"
fi

# ── 2. Behind origin ────────────────────────────────────────────────────────
# Fetch quietly so we have an up-to-date picture of the remote.
git fetch "$REMOTE" --quiet 2>/dev/null || {
    warn "could not fetch from $REMOTE — skipping behind-origin check."
}

REMOTE_REF="$REMOTE/$BRANCH"
if git rev-parse --verify "$REMOTE_REF" >/dev/null 2>&1; then
    BEHIND=$(git rev-list --count HEAD.."$REMOTE_REF")
    if [ "$BEHIND" -gt 0 ]; then
        COMMITS=$(git log --oneline HEAD.."$REMOTE_REF" | head -5)
        fail "$REMOTE/$BRANCH is $BEHIND commit(s) ahead of your local branch.
  You would overwrite parallel work. Pull or rebase first:
    git fetch $REMOTE && git rebase $REMOTE/$BRANCH

  Commits you would lose:
$(echo "$COMMITS" | sed 's/^/    /')"
    fi
fi

# ── 3. Direct push to master/main ───────────────────────────────────────────
# This is a warning, not a block — sometimes direct pushes to master are
# intentional (e.g. hotfix). But agents doing parallel work should be on
# feature branches.
if [[ "$BRANCH" == "master" || "$BRANCH" == "main" ]]; then
    warn "pushing directly to $BRANCH. If this is parallel/agent work,
  consider using a feature branch and opening a PR instead."
fi

exit 0
